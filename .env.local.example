# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL="업도움 <noreply@your-domain.com>"
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxx

# 워크넷 공공데이터 API (https://www.data.go.kr)
WORKNET_API_KEY=your-encoded-api-key

# 앱 URL (옵트아웃 링크, 웹훅 등에 사용)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 발송 안전장치 (정보통신망법 준수)
EMAIL_DAILY_CAP=50          # 발송 계정당 일일 최대 발송 수
EMAIL_PER_COMPANY_COOLDOWN_DAYS=30  # 동일 업체 재발송 금지 기간
